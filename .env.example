# ─── DATABASE ──────────────────────────────────────────────────────────────────
# Railway: copy the connection string Railway provides under Variables → DATABASE_URL
# Local dev: use the docker-compose postgres instance below
DATABASE_URL="postgresql://postgres:password@localhost:5432/pantryai"

# Same as DATABASE_URL for Railway (direct connection, no pooler).
# For Supabase with PgBouncer, set this to the direct (non-pooled) URL.
DIRECT_URL="postgresql://postgres:password@localhost:5432/pantryai"

# ─── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# ─── AI / EXTERNAL APIs ────────────────────────────────────────────────────────
OPENAI_API_KEY=""

EDAMAM_APP_ID=""
EDAMAM_APP_KEY=""
USDA_API_KEY=""

# ─── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# Railway: set to your Railway public URL, e.g. https://pantryai-server.up.railway.app
API_URL="http://localhost:3001"

# Railway + Vercel: set to your Vercel deployment URL, e.g. https://pantryai.vercel.app
# This controls CORS — the server only accepts requests from this origin.
FRONTEND_URL="http://localhost:3000"

# ─── FRONTEND (Vercel) ─────────────────────────────────────────────────────────
# Set this in Vercel → Project Settings → Environment Variables
# Value: your Railway backend URL, e.g. https://pantryai-server.up.railway.app
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── MONITORING (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=""
